# TradeTrack Backend Environment Variables
# Copy this file to .env and fill in real values.

# PostgreSQL connection string (e.g. Neon, Supabase, local)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret for signing JWT tokens — use a long, random string (min 32 chars)
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# Server port
PORT=5000

# Alpha Vantage API key (free tier at https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY="your-alpha-vantage-api-key"

# Allowed CORS origin (your Vercel frontend URL)
ALLOWED_ORIGIN="https://your-app.vercel.app"

# Log level: error | warn | info | http | debug
LOG_LEVEL="info"
